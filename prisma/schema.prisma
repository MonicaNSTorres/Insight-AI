// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String   @id @default(cuid())
  name                 String?
  email                String   @unique
  password             String?
  theme                String?  @default("light")
  language             String?  @default("pt-BR")
  notificationsEnabled Boolean? @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  datasets      Dataset[]
  conversations Conversation[]
}

model Dataset {
  id          String   @id @default(cuid())
  userId      String
  name        String
  fileName    String
  rowCount    Int
  columnCount Int
  rawJson     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  columns       DatasetColumn[]
  insights      Insight[]
  conversations Conversation[]
  chatSessions  DatasetChatSession[]
}

model DatasetColumn {
  id           String   @id @default(cuid())
  datasetId    String
  name         String
  detectedType String
  semanticRole String?
  createdAt    DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model Insight {
  id          String   @id @default(cuid())
  datasetId   String
  title       String
  description String
  priority    Int      @default(1)
  createdAt   DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  datasetId String
  userId    String
  question  String
  answer    Json
  createdAt DateTime @default(now())

  dataset Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DatasetChatSession {
  id        String   @id @default(cuid())
  datasetId String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dataset  Dataset              @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  messages DatasetChatMessage[]

  @@index([datasetId])
}

model DatasetChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metaJson  Json?
  createdAt DateTime @default(now())

  session DatasetChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
